# === DeepSeek (client OpenAI-compatible) ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.7
DEEPSEEK_MAX_TOKENS=2000
DEEPSEEK_TIMEOUT_SEC=60

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456789:ABCdef...
TELEGRAM_CHAT_ID=987654321

# === Memoria (filesystem, NON MCP) ===
# Cartella bot-memory montata in /bot-memory (vedi docker-compose: ../bot-memory).
# Contiene: il MOC (indice + sintesi + [[link]]), i default system/padrone,
# e memory.md (target di /ricorda, scrivibile → sync Obsidian).
MEMORY_DIR=/bot-memory
MOC_FILE=memory-moc.md
SYSTEM_FILE=system.md
PADRONE_FILE=padrone.md
MEMORY_FILE=memory.md

# === Bot ===
LOG_LEVEL=INFO
DB_PATH=/app/storage/bot.db
CONTEXT_WINDOW_MSGS=10

# === Scheduler ===
SCHEDULER_TICK_SEC=60
