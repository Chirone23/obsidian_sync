# Config SpecterAI — copia in `.env` (oppure esegui `python setup.py`).
# `.env` è gitignored: non committare chiavi.

# Backend LLM:
#   cli → Claude Code CLI: costo €0, funziona solo su macchina autenticata (sviluppo/demo).
#   sdk → API Anthropic via SDK: richiede ANTHROPIC_API_KEY, deployabile ovunque (produzione).
LLM_BACKEND=cli

# Modello usato da entrambi i backend.
CLAUDE_MODEL=claude-sonnet-4-6

# Richiesta SOLO se LLM_BACKEND=sdk.
ANTHROPIC_API_KEY=
